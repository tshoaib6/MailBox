# ──────────────────────────────────────────────────────────────────────────────
# COPY THIS FILE TO .env ON YOUR SERVER AND FILL IN THE VALUES
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Dnova Email Marketing"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Generate with: php artisan key:generate --show
# (run once locally: docker run --rm php:8.3-alpine php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;")
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY

# ── Database ──────────────────────────────────────────────────────────────────
DB_DATABASE=sendportal
DB_USERNAME=sendportal
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# ── Docker image ──────────────────────────────────────────────────────────────
# These are set automatically by the GitHub Actions deploy workflow.
# Set them manually only for the very first deployment.
DOCKER_USERNAME=your_dockerhub_username
IMAGE_TAG=latest
