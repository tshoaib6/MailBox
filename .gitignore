# Track our customised sendportal vendor views (smtp2go settings form, etc.)
resources/lang/vendor/
# resources/views/vendor/ — NOT ignored so our custom views are committed

# Track public/vendor assets (published from sendportal package)
# public/vendor/ — NOT ignored so they are included in Docker builds

# composer.lock SHOULD be committed for reproducible Docker builds
# composer.lock — NOT ignored

phpunit.xml

# Storage caches (never commit runtime cache files)
/storage/framework/cache/data/*
/storage/framework/views/*
/storage/framework/sessions/*
/storage/logs/*.log

